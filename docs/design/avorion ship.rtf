3.1 Blueprint Definition\par
\par
A blueprint is just block data + metadata.\par
\par
\{\par
  "name": "Bulwark Frigate",\par
  "author": "Iron Dominion AI",\par
  "faction": "iron_dominion",\par
  "seed": 842991,\par
\par
  "blocks": [\par
    \{\par
      "pos": [0,0,0],\par
      "size": [1,1,1],\par
      "shape": "Cube",\par
      "type": "Hull",\par
      "material": "Iron",\par
      "rot": 0\par
    \}\par
  ]\par
\}\par
\par
\par
No meshes. No transforms. No floats.\par
\par
3.2 Saving\par
Blueprint SaveBlueprint(Ship ship)\par
\{\par
    return new Blueprint \{\par
        Blocks = ship.Blocks.Select(BlockToData)\par
    \};\par
\}\par
\par
3.3 Loading (Deterministic)\par
Ship LoadBlueprint(Blueprint bp)\par
\{\par
    Ship ship = new Ship();\par
\par
    foreach (var block in bp.Blocks)\par
        BlockPlacement.Place(ship, block);\par
\par
    ShipRebuildPipeline.Run(ship);\par
    return ship;\par
\}\par
\par
\par
Works in:\par
\par
singleplayer\par
\par
multiplayer\par
\par
mods\par
\par
replays\par
\par
