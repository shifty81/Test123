\f2 4\u-497?\f3\u8419?\f0  Hooking Blocks into Ship Stats (Emergent Gameplay)\par
4.1 Material Stats\par
public struct MaterialStats\par
\{\par
    public float Density;\par
    public float HpMultiplier;\par
    public float EnergyBonus;\par
