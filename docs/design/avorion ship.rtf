1. Core Runtime Objects (authoritative)\par
ShipEditorController.cs\par
\par
This runs every frame only while in build mode.\par
\par
public sealed class ShipEditorController\par
\{\par
    private readonly Ship _ship;\par
    private readonly ShipEditorState _state;\par
\par
    public ShipEditorController(Ship ship)\par
    \{\par
        _ship = ship;\par
        _state = new ShipEditorState\par
        \{\par
            Mode = BuildMode.Place,\par
            SelectedShape = BlockShape.Cube,\par
            SelectedType = BlockType.Hull,\par
            SelectedMaterial = MaterialType.Iron,\par
            Symmetry = SymmetryMode.MirrorX,\par
            Rotation = Quaternion.Identity\par
        \};\par
    \}\par
\par
    public void Update(InputState input, Camera camera)\par
    \{\par
        HandleHotkeys(input);\par
        UpdateHoverCell(input.MouseRay, camera);\par
\par
        Block ghost = BuildGhostBlock();\par
        bool valid = BlockPlacement.CanPlace(_ship, ghost);\par
\par
        GhostRenderer.Draw(ghost, valid, _state.Symmetry);\par
\par
        if (input.LeftClick && valid)\par
            Place(ghost);\par
\par
        if (input.RightClick)\par
            RemoveAtHover();\par
    \}\par
\}\par
\par
\par
This file is your control center.\par
\par
2. Mouse \f5\u8594?\f1  \f0 Grid Resolution\par
Deterministic. Integer only.\par
private void UpdateHoverCell(Ray mouseRay, Camera camera)\par
\{\par
    if (!ShipRaycaster.Raycast(_ship, mouseRay, out Vector3 hit))\par
        return;\par
\par
    _state.HoverCell = Vector3Int.FloorToInt(hit / Grid.Size);\par
\}\par
\par
3. Ghost Block Construction\par
private Block BuildGhostBlock()\par
\{\par
    return new Block\par
    \{\par
        GridPos = _state.HoverCell,\par
        Size = Vector3Int.One,\par
        Shape = _state.SelectedShape,\par
        Type = _state.SelectedType,\par
        Material = _state.SelectedMaterial,\par
        Rotation = _state.Rotation,\par
        MaxHP = BlockHP.Lookup(_state.SelectedType),\par
        CurrentHP = BlockHP.Lookup(_state.SelectedType)\par
    \};\par
\}\par
\par
\par
\f4\u-10179?\u-8536?\f1  \f0 Never mutate the ship here\par
Ghosts are disposable objects.\par
\par
4. Placement (with symmetry)\par
private void Place(Block ghost)\par
\{\par
    BlockPlacement.PlaceWithSymmetry(\par
        _ship,\par
        ghost,\par
        _state.Symmetry\par
    );\par
\par
    ShipRebuildPipeline.Run(_ship);\par
\}\par
\par
5. Removal\par
private void RemoveAtHover()\par
\{\par
    if (_ship.OccupiedCells.TryGetValue(_state.HoverCell, out Block block))\par
    \{\par
        ShipDamage.RemoveBlock(_ship, block);\par
        ShipRebuildPipeline.Run(_ship);\par
    \}\par
\}\par
\par
6. Hotkeys (this matters more than you think)\par
private void HandleHotkeys(InputState input)\par
\{\par
    if (input.KeyPressed(Keys.X))\par
        _state.Symmetry ^= SymmetryMode.MirrorX;\par
\par
    if (input.KeyPressed(Keys.Y))\par
        _state.Symmetry ^= SymmetryMode.MirrorY;\par
\par
    if (input.KeyPressed(Keys.Z))\par
        _state.Symmetry ^= SymmetryMode.MirrorZ;\par
\par
    if (input.KeyPressed(Keys.R))\par
        _state.Rotation = RotationUtil.Rotate90(_state.Rotation);\par
\}\par
\par
\par
This is muscle memory UX. Avorion lives or dies here.\par
