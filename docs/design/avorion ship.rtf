4.2 Spine Construction (defines silhouette)\par
void BuildSpine()\par
\{\par
    int length = _faction.Silhouette.Length switch\par
    \{\par
        LengthBias.Short => 6,\par
        LengthBias.Balanced => 10,\par
        LengthBias.Long => 16\par
    \};\par
\par
    for (int z = 0; z < length; z++)\par
    \{\par
        PlaceHull(new Vector3Int(0, 0, z));\par
    \}\par
\}\par
\par
\par
This single loop defines:\par
\par
ship length\par
\par
center of mass\par
\par
camera framing\par
\par
4.3 Hull Expansion (thickness + void)\par
void BuildHull()\par
\{\par
    int radius = _faction.Silhouette.Thickness switch\par
    \{\par
        ThicknessBias.Thin => 1,\par
        ThicknessBias.Medium => 2,\par
        ThicknessBias.Chunky => 3\par
    \};\par
\par
    for each spine cell:\par
        expand outward\par
        skip cells if VoidBias == Channelled\par
\}\par
