\par
4.2 Block Contribution\par
public float GetBlockMass(Block b)\par
\{\par
    return b.Size.x * b.Size.y * b.Size.z\par
           * MaterialDatabase[b.Material].Density;\par
\}\par
\par
4.3 Ship Stat Rebuild (Run On Change)\par
public void RecalculateStats(Ship ship)\par
\{\par
    ship.TotalMass = 0;\par
    ship.Thrust = 0;\par
    ship.PowerGen = 0;\par
\par
    foreach (var b in ship.Blocks)\par
    \{\par
        ship.TotalMass += GetBlockMass(b);\par
\par
        if (b.Type == BlockType.Engine)\par
            ship.Thrust += b.Size.z * EnginePower(b);\par
\par
        if (b.Type == BlockType.Generator)\par
            ship.PowerGen += GeneratorOutput(b);\par
    \}\par
\}\par
\par
\par
\f4\u-10179?\u-8536?\f1  \f0 Never cache stats permanently\par
Always rebuild when blocks change.\par
\par
\f2 5\u-497?\f3\u8419?\f0  Damage \f5\u8594?\f1  \f0 Block Removal \f5\u8594?\f1  \f0 Rebuild\par
public void ApplyDamage(Block block, float dmg, Ship ship)\par
\{\par
    block.CurrentHP -= dmg;\par
