\f2 1\u-497?\f3\u8419?\f0  Block Placement System (Foundation)\par
1.1 Core Data Structures\par
BlockShape (keep this SMALL)\par
public enum BlockShape\par
\{\par
    Cube,\par
    Rect,\par
    Wedge,\par
    Corner,\par
    Slope\par
\}\par
\par
BlockType (functional meaning)\par
public enum BlockType\par
\{\par
    Hull,\par
    Armor,\par
    Engine,\par
    Generator,\par
    Gyro,\par
    Cargo,\par
    WeaponMount\par
\}\par
\par
Block Definition\par
public sealed class Block\par
\{\par
    public Vector3Int GridPos;\par
    public Vector3Int Size;          // integer dimensions\par
    public Quaternion Rotation;      // 90\'b0 increments only\par
    public BlockShape Shape;\par
    public BlockType Type;\par
    public MaterialType Material;\par
\par
    public float MaxHP;\par
    public float CurrentHP;\par
\}\par
\par
1.2 Ship Container\par
public sealed class Ship\par
\{\par
    // Every occupied grid cell maps to ONE block\par
    public Dictionary<Vector3Int, Block> OccupiedCells = new();\par
\par
    public List<Block> Blocks = new();\par
\}\par
\par
\par
\f2\u9888?\u-497?\f1  \f0 This dual structure is important\par
\f1\bullet  Blocks = iteration & stats\par
\bullet  OccupiedCells = fast overlap checks\par
\par
1.3 Placement Rules (Avorion-Correct)\par
Validation Checklist\par
\par
A block can be placed if:\par
\par
\f3\u9989?\f1  \f0 All grid cells are free\par
\f3\u9989?\f1  \f0 Touches at least one existing block (except first block)\par
\f3\u9989?\f1  \f0 Rotation is axis-aligned\par
\f3\u9989?\f1  \f0 Size aligns to grid\par
\par
Placement Code\par
public bool CanPlaceBlock(Ship ship, Block block)\par
\{\par
    foreach (var cell in GetOccupiedCells(block))\par
        if (ship.OccupiedCells.ContainsKey(cell))\par
            return false;\par
\par
    if (ship.Blocks.Count == 0)\par
        return true;\par
\par
    foreach (var cell in GetAdjacentCells(block))\par
        if (ship.OccupiedCells.ContainsKey(cell))\par
            return true;\par
\par
    return false;\par
\}\par
\par
Final Placement\par
public void PlaceBlock(Ship ship, Block block)\par
\{\par
    ship.Blocks.Add(block);\par
\par
    foreach (var cell in GetOccupiedCells(block))\par
        ship.OccupiedCells[cell] = block;\par
\}\par
\par
\f2 2\u-497?\f3\u8419?\f0  Symmetry Tools (Why Avorion Ships Look \f1\ldblquote\f0 Right\f1\rdblquote\f0 )\par
2.1 Symmetry Modes\par
[Flags]\par
public enum SymmetryMode\par
\{\par
    None = 0,\par
    MirrorX = 1,\par
    MirrorY = 2,\par
    MirrorZ = 4\par
\}\par
\par
2.2 Mirroring Logic\par
public Block CreateMirroredBlock(Block original, SymmetryMode mode)\par
\{\par
    Vector3Int pos = original.GridPos;\par
    Quaternion rot = original.Rotation;\par
\par
    if (mode.HasFlag(SymmetryMode.MirrorX))\par
        pos.x = -pos.x - original.Size.x;\par
\par
    if (mode.HasFlag(SymmetryMode.MirrorY))\par
        pos.y = -pos.y - original.Size.y;\par
\par
    if (mode.HasFlag(SymmetryMode.MirrorZ))\par
        pos.z = -pos.z - original.Size.z;\par
\par
    return new Block \{\par
        GridPos = pos,\par
        Size = original.Size,\par
        Shape = original.Shape,\par
        Type = original.Type,\par
        Material = original.Material,\par
        Rotation = rot,\par
        MaxHP = original.MaxHP,\par
        CurrentHP = original.MaxHP\par
    \};\par
\}\par
\par
Placement with Symmetry\par
public void PlaceWithSymmetry(Ship ship, Block block, SymmetryMode mode)\par
\{\par
    PlaceBlock(ship, block);\par
\par
    if (mode != SymmetryMode.None)\par
    \{\par
        Block mirrored = CreateMirroredBlock(block, mode);\par
        if (CanPlaceBlock(ship, mirrored))\par
            PlaceBlock(ship, mirrored);\par
    \}\par
\}\par
\par
\f2 3\u-497?\f3\u8419?\f0  Efficient Greedy Meshing (Performance & Clean Visuals)\par
3.1 Why You Need This\par
\par
Without greedy meshing:\par
\par
10,000 blocks = 60,000 faces \f4\u-10179?\u-8660?\f0\par
\par
