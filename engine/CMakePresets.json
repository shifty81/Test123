{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 16,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build with full assertions",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SUBSPACE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Optimized release build",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SUBSPACE_BUILD_TESTS": "OFF"
            }
        },
        {
            "name": "development",
            "displayName": "Development",
            "description": "Release with debug info for profiling",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/development",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SUBSPACE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "ci",
            "displayName": "CI",
            "description": "CI build with strict warnings",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/ci",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SUBSPACE_BUILD_TESTS": "ON"
            }
        }
    ],
    "buildPresets": [
        { "name": "debug", "configurePreset": "debug" },
        { "name": "release", "configurePreset": "release" },
        { "name": "development", "configurePreset": "development" },
        { "name": "ci", "configurePreset": "ci" },
        { "name": "tests-debug", "configurePreset": "debug", "targets": ["subspace_tests"] },
        { "name": "tests-ci", "configurePreset": "ci", "targets": ["subspace_tests"] }
    ],
    "testPresets": [
        { "name": "debug", "configurePreset": "debug", "output": { "outputOnFailure": true } },
        { "name": "ci", "configurePreset": "ci", "output": { "outputOnFailure": true } }
    ]
}
